{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "C++ 调试 (单文件)",
            "type": "cppdbg",
            "request": "launch",
            // 这里会自动指向编译出的可执行文件，必须和 tasks.json 里的输出名一致
            "program": "${fileDirname}/${fileBasenameNoExtension}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "为 gdb 启用整齐打印",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            // 关键：这里要写你编译任务的名字
            "preLaunchTask": "C/C++: g++ 生成活动文件",
            "miDebuggerPath": "/usr/bin/gdb"
        }
    ]
}